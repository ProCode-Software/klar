{
    "name": "klar",
    "displayName": "Klar",
    "description": "A programming language",
    "publisher": "procode-software",
    "version": "0.0.1",
    "license": "BSD-3-Clause",
    "engines": {
        "vscode": "^1.99.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "devDependencies": {
        "vsxtools": "link:vsxtools",
        "@vscode/vsce": "^3.7.0"
    },
    "scripts": {
        "watch": "vsxtools run",
        "build": "vsce package --no-rewrite-relative-links --no-dependencies --allow-missing-repository",
        "ext-install": "bun run build && code --install-extension ./klar-*.vsix"
    },
    "contributes": {
        "languages": [
            {
                "firstLine": "^#!\\/usr\\/bin\\env\\s+klar",
                "id": "klar",
                "aliases": ["Klar", "klar"],
                "extensions": [".klar"],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "klarmarkup",
                "aliases": [
                    "Klar Markup",
                    "klar-markup",
                    "klon",
                    "klarmarkup"
                ],
                "extensions": [".klon", "glas.pack", "klar.build"],
                "configuration": "./klon.language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "klar",
                "scopeName": "source.klar",
                "path": "./syntaxes/klar.tmLanguage.json"
            },
            {
                "language": "klarmarkup",
                "scopeName": "source.klarmarkup",
                "path": "./syntaxes/klon.tmLanguage.json"
            },
            {
                "scopeName": "markdown.klar.codeblock",
                "path": "./syntaxes/codeblock.tmLanguage.json",
                "injectTo": ["text.html.markdown"],
                "embeddedLanguages": {
                    "meta.embedded.block.klar": "klar",
                    "meta.embedded.block.klarmarkup": "klarmarkup"
                }
            }
        ]
    }
}
