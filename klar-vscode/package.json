{
    "name": "klar",
    "displayName": "Klar",
    "version": "0.0.1",
    "description": "A programming language",
    "categories": [
        "Programming Languages"
    ],
    "license": "Apache-2.0",
    "publisher": "procode-software",
    "type": "module",
    "scripts": {
        "watch": "vsxtools run",
        "build": "vsce package --no-rewrite-relative-links --no-dependencies --allow-missing-repository",
        "ext-install": "bun run build && code --install-extension ./klar-*.vsix"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.7.0",
        "vsxtools": "latest"
    },
    "contributes": {
        "languages": [
            {
                "firstLine": "^#!\\/usr\\/bin\\env\\s+klar",
                "id": "klar",
                "aliases": [
                    "Klar",
                    "klar"
                ],
                "extensions": [
                    ".klar"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "klon",
                "aliases": [
                    "Klon",
                    "klon"
                ],
                "extensions": [
                    ".klon",
                    "glas.pack",
                    "klar.build"
                ],
                "configuration": "./klon.language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "klar",
                "scopeName": "source.klar",
                "path": "./syntaxes/klar.tmLanguage.json"
            },
            {
                "language": "klon",
                "scopeName": "source.klon",
                "path": "./syntaxes/klon.tmLanguage.json"
            },
            {
                "scopeName": "markdown.klar.codeblock",
                "path": "./syntaxes/codeblock.tmLanguage.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.klar": "klar",
                    "meta.embedded.block.klon": "klon"
                }
            }
        ]
    },
    "engines": {
        "vscode": "^1.99.0"
    }
}
