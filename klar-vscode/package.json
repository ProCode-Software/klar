{
    "name": "klar",
    "displayName": "Klar",
    "description": "A programming language",
    "publisher": "procode-software",
    "version": "0.0.1",
    "license": "BSD-3-Clause",
    "engines": {
        "vscode": "^1.99.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "devDependencies": {
        "vsxtools": "link:vsxtools",
        "@vscode/vsce": "3.3.2"
    },
    "scripts": {
        "watch": "bun watch-klar & bun watch-klarml & bun watch-codeblock",
        "watch-klar": "vsxtools build-grammar src/klar.ts syntaxes/klar.tmLanguage.json --watch",
        "watch-klarml": "vsxtools build-grammar src/klarml.ts syntaxes/klarml.tmLanguage.json --watch",
        "watch-codeblock": "vsxtools build-grammar src/codeblock.ts syntaxes/codeblock.tmLanguage.json --watch",
        "build": "vsce package --no-rewrite-relative-links --no-dependencies --allow-missing-repository"
    },
    "contributes": {
        "languages": [
            {
                "firstLine": "^#!\\/usr\\/bin\\env\\s+klar",
                "id": "klar",
                "aliases": [ "Klar", "klar" ],
                "extensions": [ ".klar" ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "klarmarkup",
                "aliases": [
                    "Klar Markup",
                    "klar-markup",
                    "klarml",
                    "klarmarkup"
                ],
                "extensions": [ ".klarml", "glas.pack" ],
                "configuration": "./klarml.language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "klar",
                "scopeName": "source.klar",
                "path": "./syntaxes/klar.tmLanguage.json"
            },
            {
                "language": "klarmarkup",
                "scopeName": "source.klarmarkup",
                "path": "./syntaxes/klarml.tmLanguage.json"
            },
            {
                "scopeName": "markdown.klar.codeblock",
                "path": "./syntaxes/codeblock.tmLanguage.json",
                "injectTo": [ "text.html.markdown" ],
                "embeddedLanguages": {
                    "meta.embedded.block.klar": "klar",
                    "meta.embedded.block.klarmarkup": "klarmarkup"
                }
            }
        ]
    }
}
