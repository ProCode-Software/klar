{
    "name": "Klar",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#booleans"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#castFunctions"
        },
        {
            "include": "#functionDeclarations"
        },
        {
            "include": "#structs"
        },
        {
            "include": "#typeAliasDeclarations"
        },
        {
            "include": "#importStatements"
        },
        {
            "include": "#variableAssignments"
        },
        {
            "include": "#whenExpression"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "begin": "\\/{2}",
                    "end": "$",
                    "name": "comment.line.double-slash.klar"
                },
                {
                    "begin": "\\/\\*",
                    "end": "\\*\\/",
                    "name": "comment.block.klar"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "begin": "\"",
                    "end": "\"",
                    "name": "string.quoted.double.klar",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.klar"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.klar"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#stringEscape"
                        },
                        {
                            "include": "#stringInterpolation"
                        }
                    ]
                },
                {
                    "begin": "'",
                    "end": "'",
                    "name": "string.quoted.single.klar",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.klar"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.klar"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#stringEscape"
                        }
                    ]
                },
                {
                    "begin": "`",
                    "end": "`",
                    "name": "string.quoted.raw.klar",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.klar"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.klar"
                        }
                    },
                    "patterns": []
                }
            ]
        },
        "stringEscape": {
            "patterns": [
                {
                    "match": "\\\\(?:x[0-9a-fA-F]{2}|u{0*[0-9a-fA-F]{1,6}}|u[0-9a-fA-F]{4}|.)",
                    "name": "constant.character.escape.klar"
                }
            ]
        },
        "stringInterpolation": {
            "begin": "{",
            "end": "}",
            "contentName": "meta.interpolated-string.klar source.klar",
            "patterns": [
                {
                    "include": "$base"
                }
            ],
            "captures": {
                "0": {
                    "name": "punctuation.definition.string-interpolation.klar"
                }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(type)\\b",
                    "name": "storage.type.type.klar"
                },
                {
                    "match": "\\b(func)\\b",
                    "name": "storage.type.function.klar"
                },
                {
                    "match": "\\b(for|next)\\b",
                    "name": "keyword.control.loop.klar"
                },
                {
                    "match": "\\b(return)\\b",
                    "name": "keyword.control.flow.klar"
                },
                {
                    "match": "\\b(when|import)\\b",
                    "name": "keyword.control.$1.klar"
                }
            ]
        },
        "booleans": {
            "patterns": [
                {
                    "match": "\\b(true|false)\\b",
                    "name": "constant.language.boolean.$1.klar"
                },
                {
                    "match": "\\b(nil)\\b",
                    "name": "constant.language.nil.klar"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "\\b0[xX][0-9A-Fa-f_]+\\b",
                    "name": "constant.numeric.hex.klar"
                },
                {
                    "match": "\\b0[oO][0-7_]+\\b",
                    "name": "constant.numeric.octal.klar"
                },
                {
                    "match": "\\b0[bB][0-1]+\\b",
                    "name": "constant.numeric.binary.klar"
                },
                {
                    "match": "\\b[\\d_]+(?:e[+-]?[\\d_]+)?\\.[\\d_]+(?:e[+-]?[\\d_]+)?\\b",
                    "name": "constant.numeric.decimal.klar"
                },
                {
                    "match": "\\.[\\d_]+(?:e[+-]?[\\d_]+)?\\b",
                    "name": "constant.numeric.decimal.klar"
                },
                {
                    "match": "\\b[\\d_]+(?:e[+-]?[\\d_]+)?\\.",
                    "name": "constant.numeric.decimal.klar"
                },
                {
                    "match": "[\\d_]+(?:e[+-]?[\\d_]+)",
                    "name": "constant.numeric.decimal.klar"
                },
                {
                    "match": "\\b(?:\\d+_?)+\\b",
                    "name": "constant.numeric.decimal.klar"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "match": "\\|>",
                    "name": "keyword.operator.pipe.klar"
                },
                {
                    "match": "->",
                    "name": "keyword.operator.arrow.klar"
                },
                {
                    "match": "\\.{3}",
                    "name": "keyword.operator.spread.klar"
                },
                {
                    "match": "\\.{2}",
                    "name": "keyword.operator.range.klar"
                },
                {
                    "match": "&&|\\|{2}|!",
                    "name": "keyword.operator.logical.klar"
                },
                {
                    "match": "[><=!]=|[<>]",
                    "name": "keyword.operator.comparison.klar"
                },
                {
                    "match": "[&|?]",
                    "name": "keyword.operator.type.klar"
                },
                {
                    "match": "[-+*/%^:]?=",
                    "name": "keyword.operator.assignment.klar"
                },
                {
                    "match": "[-+*/%^]",
                    "name": "keyword.operator.arithmetic.klar"
                },
                {
                    "match": "=",
                    "name": "keyword.operator.assignment.klar"
                }
            ]
        },
        "functions": {
            "begin": "(_?[\\p{L}_][\\p{L}\\w_]*)\\s*(\\()",
            "end": "\\)",
            "name": "meta.function-call.klar",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.function.klar",
                    "patterns": [
                        {
                            "include": "#builtinFunctions"
                        }
                    ]
                },
                "2": {
                    "name": "punctuation.definition.arguments.begin.klar"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.arguments.end.klar"
                }
            },
            "patterns": [
                {
                    "include": "#labels"
                },
                {
                    "include": "$base"
                }
            ]
        },
        "builtinFunctions": {
            "match": "\\b(print|panic|TODO)\\b",
            "name": "support.function.builtin.klar"
        },
        "castFunctions": {
            "begin": "(?:(\\b(?:String|Int|Float|Bool|Error|List|Dictionary)\\b\\??)|\\[(((?:_?[\\p{L}_][\\p{L}\\w_]*\\.)?_?[\\p{L}_][\\p{L}\\w_]*(?:<[\\s\\p{L}\\w._,?<>\\[\\]\\-()]+>)?\\??)|\\[\\s*\\g<2>\\s*\\]\\??)\\])(\\()",
            "end": "\\)",
            "beginCaptures": {
                "1": {
                    "name": "support.type.builtin.klar support.type.primitive.klar",
                    "patterns": [
                        {
                            "include": "#types"
                        }
                    ]
                },
                "2": {
                    "name": "entity.name.type.klar",
                    "patterns": [
                        {
                            "include": "#types"
                        }
                    ]
                },
                "5": {
                    "name": "punctuation.definition.arguments.begin.klar"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.arguments.end.klar"
                }
            },
            "patterns": [
                {
                    "include": "$base"
                }
            ],
            "name": "meta.type-cast.klar"
        },
        "functionDeclarations": {
            "begin": "(?<=\\bfunc\\b)\\s*(?:(?:(_?[\\p{L}_][\\p{L}\\w_]*)(\\.))?(_?[\\p{L}_][\\p{L}\\w_]*))?\\s*(\\()",
            "end": "(\\))(?:\\s*(->)\\s*(((?:_?[\\p{L}_][\\p{L}\\w_]*\\.)?_?[\\p{L}_][\\p{L}\\w_]*(?:<[\\s\\p{L}\\w._,?<>\\[\\]\\-()]+>)?\\??)|\\[\\s*\\g<2>\\s*\\]\\??))?",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.type.struct.klar"
                },
                "2": {
                    "name": "punctuation.separator.period.klar"
                },
                "3": {
                    "name": "entity.name.function.klar"
                },
                "4": {
                    "name": "punctuation.definition.arguments.begin.klar"
                }
            },
            "endCaptures": {
                "1": {
                    "name": "punctuation.definition.arguments.end.klar"
                },
                "2": {
                    "name": "keyword.operator.return-type.klar"
                },
                "3": {
                    "name": "entity.name.type.klar",
                    "patterns": [
                        {
                            "include": "#types"
                        }
                    ]
                }
            },
            "patterns": [
                {
                    "match": "(?<=^|[(,])\\s*(\\b_?[\\p{L}_][\\p{L}\\w_]*\\b)?\\s*(_?[\\p{L}_][\\p{L}\\w_]*)\\s*(:)\\s*(((?:_?[\\p{L}_][\\p{L}\\w_]*\\.)?_?[\\p{L}_][\\p{L}\\w_]*(?:<[\\s\\p{L}\\w._,?<>\\[\\]\\-()]+>)?\\??)|\\[\\s*\\g<2>\\s*\\]\\??)",
                    "captures": {
                        "1": {
                            "name": "variable.parameter.klar"
                        },
                        "2": {
                            "name": "variable.other.klar"
                        },
                        "3": {
                            "name": "keyword.operator.type.annotation.klar"
                        },
                        "4": {
                            "name": "entity.name.type.klar",
                            "patterns": [
                                {
                                    "include": "#types"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "match": "_?[\\p{L}_][\\p{L}\\w_]*(?=\\.)",
                    "name": "entity.name.namespace.klar"
                },
                {
                    "match": "\\b(String|Int|Float|Bool|Result|List|Dictionary|Any|Never|Nothing|Error)(?!\\.)\\b",
                    "name": "support.type.builtin.klar support.type.primitive.klar"
                },
                {
                    "match": "[&|?]",
                    "name": "keyword.operator.type.klar"
                },
                {
                    "match": "[<>]",
                    "name": "punctuation.definition.generic.klar"
                },
                {
                    "match": "[\\[\\]]",
                    "name": "punctuation.definition.type.array.klar"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.klar"
                },
                {
                    "match": "\\.",
                    "name": "punctuation.separator.period.klar"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "match": "\\b(self)\\b",
                    "name": "variable.language.self.klar"
                },
                {
                    "match": "_?[\\p{Lu}_][\\p{Lu}\\d_]*",
                    "name": "variable.other.constant.klar"
                },
                {
                    "match": "_?[\\p{L}_][\\p{L}\\w_]*",
                    "name": "variable.other.readwrite.klar"
                },
                {
                    "match": "(\\B\\.)(_?[\\p{L}_][\\p{L}\\w_]*)",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.enum.klar"
                        },
                        "2": {
                            "name": "variable.other.enummember.klar"
                        }
                    }
                }
            ]
        },
        "labels": {
            "match": "(?<=^|[(,])\\s*(_?[\\p{L}_][\\p{L}\\w_]*)\\s*(:)",
            "captures": {
                "1": {
                    "name": "variable.parameter.klar"
                },
                "2": {
                    "name": "punctuation.separator.label.parameter.klar"
                }
            }
        },
        "punctuation": {
            "patterns": [
                {
                    "match": "[{}]",
                    "name": "punctuation.definition.block.klar"
                },
                {
                    "match": "[\\[\\]]",
                    "name": "punctuation.definition.bracket"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.klar"
                },
                {
                    "match": ";",
                    "name": "invalid.semicolon.klar"
                },
                {
                    "match": "\\.",
                    "name": "punctuation.separator.period.klar"
                }
            ]
        },
        "importStatements": {
            "begin": "(?<=\\bimport\\b)",
            "beginCaptures": {
                "0": {
                    "patterns": [
                        {
                            "include": "$base"
                        }
                    ]
                }
            },
            "end": "$",
            "name": "meta.import.klar",
            "contentName": "entity.name.namespace.klar",
            "patterns": [
                {
                    "begin": "\\.\\s*{",
                    "end": "}",
                    "captures": {
                        "0": {
                            "name": "punctuation.definition.unqualified-import.klar"
                        }
                    },
                    "contentName": "variable.other.klar",
                    "patterns": [
                        {
                            "match": "(?:(_?[\\p{L}_][\\p{L}\\w_]*)\\s*(:)\\s*)?\\b(type)\\b\\s*(_?[\\p{L}_][\\p{L}\\w_]*)",
                            "captures": {
                                "1": {
                                    "name": "entity.name.type.klar"
                                },
                                "2": {
                                    "name": "keyword.operator.import-as.klar"
                                },
                                "3": {
                                    "name": "keyword.control.type.klar"
                                },
                                "4": {
                                    "name": "entity.name.type.klar"
                                }
                            }
                        },
                        {
                            "match": ",",
                            "name": "punctuation.separator.comma.klar"
                        },
                        {
                            "match": ":",
                            "name": "keyword.operator.import-as.klar"
                        },
                        {
                            "match": "\\*",
                            "name": "keyword.operator.wildcard.klar"
                        }
                    ]
                },
                {
                    "match": "\\.",
                    "name": "punctuation.accessor.namespace.klar"
                },
                {
                    "match": ":",
                    "name": "keyword.operator.import-as.klar"
                },
                {
                    "match": "\\*",
                    "name": "keyword.operator.wildcard.klar"
                }
            ]
        },
        "typeAliasDeclarations": {
            "begin": "(?<=\\btype\\b)\\s*(_?[\\p{L}_][\\p{L}\\w_]*)\\s*(=)\\s*(((?:_?[\\p{L}_][\\p{L}\\w_]*\\.)?_?[\\p{L}_][\\p{L}\\w_]*(?:<[\\s\\p{L}\\w._,?<>\\[\\]\\-()]+>)?\\??)|\\[\\s*\\g<2>\\s*\\]\\??)",
            "end": "$",
            "name": "meta.typealias-declaration.klar",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.type.klar"
                },
                "2": {
                    "name": "keyword.operator.assignment.klar"
                },
                "3": {
                    "name": "entity.name.type.klar",
                    "patterns": [
                        {
                            "include": "#types"
                        }
                    ]
                }
            }
        },
        "structs": {
            "name": "meta.type.klar",
            "begin": "(?<=\\btype\\b)\\s*(_?[\\p{L}_][\\p{L}\\w_]*)\\s*(?:\\((((?:_?[\\p{L}_][\\p{L}\\w_]*\\.)?_?[\\p{L}_][\\p{L}\\w_]*(?:<[\\s\\p{L}\\w._,?<>\\[\\]\\-()]+>)?\\??)|\\[\\s*\\g<2>\\s*\\]\\??)\\))?\\s*({)",
            "end": "}",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.type.struct.klar"
                },
                "2": {
                    "name": "entity.other.inherited-type.klar",
                    "patterns": [
                        {
                            "include": "#types"
                        }
                    ]
                },
                "4": {
                    "name": "punctuation.definition.block.begin.klar"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.block.end.klar"
                }
            },
            "patterns": [
                {
                    "match": "(?<=^|{)\\s*(_?[\\p{L}_][\\p{L}\\w_]*)\\s*(:)\\s*(((?:_?[\\p{L}_][\\p{L}\\w_]*\\.)?_?[\\p{L}_][\\p{L}\\w_]*(?:<[\\s\\p{L}\\w._,?<>\\[\\]\\-()]+>)?\\??)|\\[\\s*\\g<2>\\s*\\]\\??)(?:\\s*(=)(.+)(?=$))?",
                    "captures": {
                        "1": {
                            "name": "variable.other.klar"
                        },
                        "2": {
                            "name": "keyword.operator.type.annotation.klar"
                        },
                        "3": {
                            "name": "entity.name.type.klar",
                            "patterns": [
                                {
                                    "include": "#types"
                                }
                            ]
                        },
                        "5": {
                            "name": "keyword.operator.assignment.klar"
                        },
                        "6": {
                            "patterns": [
                                {
                                    "include": "$base"
                                }
                            ]
                        }
                    }
                },
                {
                    "include": "#enums"
                },
                {
                    "match": ",",
                    "name": "invalid.comma.klar"
                }
            ]
        },
        "enums": {
            "patterns": [
                {
                    "match": "(_?[\\p{L}_][\\p{L}\\w_]*)(?:\\s*(=)\\s*(.+)\\s*(?=$|}|\\|))?",
                    "captures": {
                        "1": {
                            "name": "variable.other.enummember.klar"
                        },
                        "2": {
                            "name": "keyword.operator.assignment.klar"
                        },
                        "3": {
                            "patterns": [
                                {
                                    "include": "$base"
                                }
                            ]
                        }
                    }
                },
                {
                    "match": "\\|",
                    "name": "keyword.operator.type.klar"
                }
            ]
        },
        "variableAssignments": {
            "begin": "(_?[\\p{L}_][\\p{L}\\w_]*)(?:\\s*(:)\\s*(((?:_?[\\p{L}_][\\p{L}\\w_]*\\.)?_?[\\p{L}_][\\p{L}\\w_]*(?:<[\\s\\p{L}\\w._,?<>\\[\\]\\-()]+>)?\\??)|\\[\\s*\\g<2>\\s*\\]\\??))?\\s*(:=)",
            "beginCaptures": {
                "1": {
                    "name": "variable.other.assignment.klar",
                    "patterns": [
                        {
                            "include": "#variables"
                        }
                    ]
                },
                "2": {
                    "name": "keyword.operator.type.annotation.klar"
                },
                "3": {
                    "name": "entity.name.type.klar",
                    "patterns": [
                        {
                            "include": "#types"
                        }
                    ]
                },
                "5": {
                    "name": "keyword.operator.assignment.klar"
                }
            },
            "patterns": [
                {
                    "include": "$base"
                }
            ],
            "end": "$"
        },
        "whenExpression": {
            "begin": "(?<=\\bwhen\\b)(.+)({)",
            "end": "}",
            "beginCaptures": {
                "1": {
                    "name": "meta.block.when.expression.klar",
                    "patterns": [
                        {
                            "include": "$base"
                        }
                    ]
                },
                "2": {
                    "name": "punctuation.definition.block.begin.klar"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.block.begin.klar"
                }
            },
            "name": "meta.block.when.klar",
            "patterns": [
                {
                    "match": "\\|(?!\\|)",
                    "name": "keyword.operator.alternative.klar"
                },
                {
                    "match": "\\b_\\b",
                    "name": "keyword.operator.default.klar"
                },
                {
                    "include": "$base"
                }
            ]
        }
    },
    "scopeName": "source.klar"
}