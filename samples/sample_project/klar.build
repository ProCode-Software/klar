// Test Klar build configuration
target: browser
verbose: true

input: ./src/proj
emitPackage: true
output: ./dist/proj

$baseJSOptions.globals:
    - JSON: @js/Object
    - PI: @const Float
    - document: js/document

js:
    - declaration: true
    - jsdoc: true
    - bundle: true
    - typescriptLibs: DOM
    - $baseJSOptions

postBuild: @print Build complete!

preBuild: [lint, generate, format]
