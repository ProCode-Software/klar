target: browser

input:
    @file main.klar,
    @dir src

output: dist/[dir]/main.js
bundle: true
verbose: true

js:
    - declaration: true
    - declarationDir: types
    - jsdoc: true
    - format: esm, umd
    - globals: // Define global types
        -- Object:
        -- PI: @const Float
        -- Document: null

preBuild:
    - lint
    - generate
    - format

postBuild:
    - @copy from -> to
    - @shell "npm publish"
    - @print "Hello, World!"
