type Program {
    commands: [Command]
    comments: [Comment]
}

type Command {
    name: String
    args: [Value]
    flags: [Flag]
}

type Comment {
    text: String
}

type Flag {
    name: String
    isShort: Bool
    Value: Value
}

type #Value

type StringValue: Value {
    value: String
    singleQuote: Bool
}

type IntValue: Value { value: Int }
type BoolValue: Value { value: Bool }
