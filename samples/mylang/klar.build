// Test Klar build configuration
target: browser
verbose: true

input: ./src/mylang/mylang.klar
generatePackage: true
output: ./dist

js:
    - declaration: true
    - jsdoc: true
    - bundle: true
    - typescriptLibs: DOM
    - <- $baseJSOptions
    - server:
        -- port: 3000
        -- document: ./index.html
    - esnext: true

postBuild: @print Build complete!

preBuild: [lint, generate, format]

$baseJSOptions: 
    