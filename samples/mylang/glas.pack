name: klar/compilerTypes
version: v1.0.0
description: A programming language written in Klar

klar: v0.0.1
target: js

js:
  - defaultRuntime: bun

dependencies:
  - @npm proicons/react latest
  - github.com/ProCode-Software/proicons @pkg proicons-react v4.2
  - mysite.com/myrepo +commitid @pkg whatever 
  - @workspace myother
