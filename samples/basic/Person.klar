type Gender { .male, .female, .nonBinary, .other }

type Person {
    name: String
    age: Int
    gender: Gender?
}

func Person.greet(otherPerson: String) {
    print("Hello {otherPerson}! My name is {self.name}.")
}

people: [Person] := [
    Person(name: "John", age: 34, gender: .male),
    .("Jane", age: 32, gender: .female),
]
print(people)
people[0].greet("Lucy")
